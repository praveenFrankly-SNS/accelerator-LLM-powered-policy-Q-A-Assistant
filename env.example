# Databricks Environment Configuration
# Copy this file to .env and fill in your values

# Databricks workspace
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com/
DATABRICKS_TOKEN=your-access-token-here

# Optional: SQL Warehouse ID (for SQL-based queries)
# Get this from: Databricks → SQL Warehouses → Copy warehouse ID
DATABRICKS_WAREHOUSE_ID=your-warehouse-id-here

# Optional: Service Principal for production deployment
DATABRICKS_SERVICE_PRINCIPAL_NAME=your-service-principal@company.com

# Unity Catalog configuration
CATALOG_NAME=dev_policy_qa
SCHEMA_NAME=policy_assistant

# Model configuration (defaults — override if needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=google/flan-t5-base
